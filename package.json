{
  "name": "codex-cost-extension",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.2.2",
  "packageManager": "pnpm@11.7.0",
  "publisher": "gambjako",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gamjak/codex_cost_extension.git"
  },
  "homepage": "https://github.com/gamjak/codex_cost_extension#readme",
  "bugs": {
    "url": "https://github.com/gamjak/codex_cost_extension/issues"
  },
  "keywords": [
    "codex",
    "usage",
    "tokens",
    "cost",
    "budget"
  ],
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:codexCost.usage",
    "onCommand:codexCost.refresh",
    "onCommand:codexCost.setScopeWorkspace",
    "onCommand:codexCost.setScopeAll",
    "onCommand:codexCost.openSettings"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexCost",
          "title": "Codex Cost",
          "icon": "resources/codex-cost.svg"
        }
      ]
    },
    "views": {
      "codexCost": [
        {
          "id": "codexCost.usage",
          "name": "%view.usage%"
        }
      ]
    },
    "commands": [
      {
        "command": "codexCost.refresh",
        "title": "%command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "codexCost.setScopeWorkspace",
        "title": "%command.workspace%",
        "icon": "$(folder)"
      },
      {
        "command": "codexCost.setScopeAll",
        "title": "%command.all%",
        "icon": "$(globe)"
      },
      {
        "command": "codexCost.openSettings",
        "title": "%command.settings%",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codexCost.refresh",
          "when": "view == codexCost.usage",
          "group": "navigation"
        },
        {
          "command": "codexCost.setScopeWorkspace",
          "when": "view == codexCost.usage",
          "group": "navigation@1"
        },
        {
          "command": "codexCost.setScopeAll",
          "when": "view == codexCost.usage",
          "group": "navigation@2"
        },
        {
          "command": "codexCost.openSettings",
          "when": "view == codexCost.usage",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Codex Cost",
      "properties": {
        "codexCost.logRoots": {
          "type": "array",
          "default": [
            "%USERPROFILE%/.codex/sessions"
          ],
          "items": {
            "type": "string"
          },
          "description": "Directories to scan for local Codex session JSONL files."
        },
        "codexCost.sources.include": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Optional source filter, for example [\"vscode\", \"cli\"]. Leave empty to include all sources."
        },
        "codexCost.pricing.models": {
          "type": "object",
          "default": {
            "gpt-5.6-sol": {
              "inputPer1M": 5,
              "cachedInputPer1M": 0.5,
              "outputPer1M": 30
            },
            "gpt-5.6-terra": {
              "inputPer1M": 2.5,
              "cachedInputPer1M": 0.25,
              "outputPer1M": 15
            },
            "gpt-5.6-luna": {
              "inputPer1M": 1,
              "cachedInputPer1M": 0.1,
              "outputPer1M": 6
            },
            "gpt-5.4": {
              "inputPer1M": 2.5,
              "cachedInputPer1M": 0.25,
              "outputPer1M": 15
            },
            "gpt-5.4-mini": {
              "inputPer1M": 0.75,
              "cachedInputPer1M": 0.075,
              "outputPer1M": 4.5
            },
            "gpt-5.4-nano": {
              "inputPer1M": 0.2,
              "cachedInputPer1M": 0.02,
              "outputPer1M": 1.25
            },
            "gpt-5.4-pro": {
              "inputPer1M": 30,
              "cachedInputPer1M": 30,
              "outputPer1M": 180
            },
            "gpt-5.5": {
              "inputPer1M": 5,
              "cachedInputPer1M": 0.5,
              "outputPer1M": 30
            },
            "gpt-5.5-pro": {
              "inputPer1M": 30,
              "cachedInputPer1M": 30,
              "outputPer1M": 180
            }
          },
          "description": "Per-model pricing used for local estimated cost. Dated model variants inherit the longest matching configured model family.",
          "additionalProperties": {
            "type": "object",
            "required": [
              "inputPer1M",
              "cachedInputPer1M",
              "outputPer1M"
            ],
            "properties": {
              "inputPer1M": {
                "type": "number",
                "minimum": 0,
                "description": "Price for one million non-cached input tokens."
              },
              "cachedInputPer1M": {
                "type": "number",
                "minimum": 0,
                "description": "Price for one million cached input tokens."
              },
              "outputPer1M": {
                "type": "number",
                "minimum": 0,
                "description": "Price for one million output tokens."
              }
            }
          }
        },
        "codexCost.scopeDefault": {
          "type": "string",
          "enum": [
            "workspace",
            "all"
          ],
          "default": "workspace",
          "description": "Default scope used when the Codex Cost view opens."
        },
        "codexCost.autoRefreshSeconds": {
          "type": "integer",
          "default": 60,
          "minimum": 0,
          "maximum": 86400,
          "description": "Automatic refresh interval in seconds for the Codex Cost sidebar and status bar. Set to 0 to disable auto-refresh."
        },
        "codexCost.filter.startDate": {
          "type": "string",
          "default": "",
          "description": "Fixed inclusive start date for displayed usage in DD.MM.YYYY format, for example 01.01.2000. Leave empty to disable the filter."
        },
        "codexCost.budget.dayAmount": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily budget in USD. This defines the value for the day period. Set to 0 to leave the daily budget unconfigured."
        },
        "codexCost.budget.weekAmount": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Weekly budget in USD. This defines the value for the week period. Set to 0 to leave the weekly budget unconfigured."
        },
        "codexCost.budget.monthAmount": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Monthly budget in USD. This defines the value for the month period. Set to 0 to leave the monthly budget unconfigured."
        },
        "codexCost.budget.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show one warning when the selected workspace budget reaches its threshold and one when it is exceeded. Enabled by default."
        },
        "codexCost.budget.warningPercent": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "Warning threshold in percent for configured budgets."
        },
        "codexCost.statusBar.showSession": {
          "type": "boolean",
          "default": true,
          "description": "Show the current session estimate in the VS Code status bar."
        },
        "codexCost.statusBar.showWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Show the current workspace estimate in the VS Code status bar."
        },
        "codexCost.statusBar.showBudget": {
          "type": "boolean",
          "default": true,
          "description": "Show or hide the budget item in the VS Code status bar."
        },
        "codexCost.statusBar.budgetPeriod": {
          "type": "string",
          "enum": [
            "day",
            "week",
            "month"
          ],
          "default": "month",
          "enumDescriptions": [
            "Show the configured daily budget amount in the status bar.",
            "Show the configured weekly budget amount in the status bar.",
            "Show the configured monthly budget amount in the status bar."
          ],
          "description": "Choose which configured budget period is shown in the VS Code status bar. This changes only the displayed period, not the stored budget values."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit && eslint . && vitest run",
    "lint": "eslint .",
    "package": "vsce package --no-dependencies",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "vscode:prepublish": "tsc -p tsconfig.build.json && eslint . && vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.17.0",
    "@types/vscode": "1.96.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.8"
  }
}
